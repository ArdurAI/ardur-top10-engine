{
  "name": "@ardurai/top10-engine",
  "version": "0.1.0",
  "private": false,
  "description": "Top-10 selection and 6-hour refresh orchestration for the Ardur AI content pipeline",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --experimental-strip-types \"src/**/*.test.ts\"",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "select": "node --experimental-strip-types src/cli.ts",
    "cycle-info": "node --experimental-strip-types src/orchestrate.ts"
  },
  "keywords": [
    "ardur",
    "top10",
    "orchestration",
    "scheduler",
    "content-pipeline"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ArdurAI/ardur-top10-engine.git"
  },
  "dependencies": {
    "@ardurai/contracts": "github:ArdurAI/ardur-contracts#4667a8b1b6886faef40b13d21923e446d64f608d",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "^22.10.0",
    "eslint": "9.39.4",
    "prettier": "3.8.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "8.61.0"
  }
}
