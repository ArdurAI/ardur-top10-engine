{
  "name": "@ardurai/top10-engine",
  "version": "0.1.0",
  "private": false,
  "description": "Top-10 selection and 6-hour refresh orchestration for the Ardur AI content pipeline",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": "./dist/index.js",
    "./contracts": "./dist/contracts.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --experimental-strip-types src/smoke.test.ts",
    "select": "node --experimental-strip-types src/cli.ts",
    "orchestrate": "node --experimental-strip-types src/orchestrate.ts"
  },
  "keywords": [
    "ardur",
    "top10",
    "orchestration",
    "scheduler",
    "content-pipeline"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ArdurAI/ardur-top10-engine.git"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.10.0"
  }
}
